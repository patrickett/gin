{
  "name": "gin",
  "displayName": "Gin",
  "description": "Language support for the Gin programming language (syntax highlighting and ginlsp).",
  "version": "0.1.0",
  "publisher": "patrickett",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/patrickett/gin"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    
    "workspaceContains:**/*.gin"
    
  ],
  "contributes": {
    "commands": [
      {
        "command": "gin.restartLanguageServer",
        "title": "Restart Language Server",
        "category": "Gin"
      }
    ],
    "languages": [
      {
        "id": "gin",
        "aliases": [
          "Gin"
        ],
        "extensions": [
          ".gin"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gin",
        "scopeName": "source.gin",
        "path": "./syntaxes/gin.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Gin",
      "properties": {
        "gin.ginlsp.path": {
          "type": "string",
          "default": "",
          "description": "Path to the ginlsp executable. When empty, the extension runs ginlsp from your PATH."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "publish:open-vsx": "ovsx publish",
    "publish:marketplace": "vsce publish"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.3.2",
    "ovsx": "^0.10.6",
    "typescript": "^5.7.2"
  }
}
