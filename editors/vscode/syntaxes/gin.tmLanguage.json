{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Gin",
  "scopeName": "source.gin",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings-double" },
    { "include": "#strings-single" },
    { "include": "#numbers" },
    { "include": "#keywords" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.gin",
          "match": "---[^\\n]*"
        },
        {
          "name": "comment.line.double-dash.gin",
          "match": "--[^\\n]*"
        }
      ]
    },
    "strings-double": {
      "name": "string.quoted.double.gin",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.gin", "match": "\\\\." },
        {
          "name": "meta.embedded.expression.gin",
          "begin": "\\{",
          "end": "\\}"
        }
      ]
    },
    "strings-single": {
      "name": "string.quoted.single.gin",
      "begin": "'",
      "end": "'",
      "patterns": [{ "name": "constant.character.escape.gin", "match": "\\\\." }]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.gin",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.float.gin",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.gin",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.gin",
          "match": "\\b(?:if|when|then|else|for|while|loop|return)\\b"
        },
        {
          "name": "keyword.declaration.gin",
          "match": "\\b(?:use|private|has|is|or|extern)\\b"
        },
        {
          "name": "keyword.operator.word.gin",
          "match": "\\b(?:in|as|self)\\b"
        }
      ]
    }
  }
}
